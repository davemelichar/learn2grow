---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/globals.css';
---

<Layout title="ESG in Practice: Supporting Clients on Their Sustainability Journey - learn2grow">

<Nav />

<!-- Article Header -->
<header class="article-header">
    <span class="article-category-badge" data-i18n="articleCategory">News</span>
    <h1 class="article-title" data-i18n="articleTitle">ESG in Practice: Supporting Clients on Their Sustainability Journey</h1>
    <p class="article-meta" data-i18n="articleDate">January 13, 2025</p>
</header>

<!-- Article Content -->
<article class="article-content">
    <a href="/insights" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"></path>
        </svg>
        <span data-i18n="backToInsights">Back to Insights</span>
    </a>

    <div class="article-image-block">
        <img loading="lazy" src="/images/article3.jpg" alt="ESG in Practice" />
    </div>

    <div class="article-intro">
        <p data-i18n="articleIntro">At learn2grow, we believe that real change within an organization starts with people and their understanding of new challenges. In one of our projects, we became the facilitators on the "Sustainability Journey" for Home Credit and its subsidiaries around the world.</p>
    </div>

    <section class="article-section">
        <p data-i18n="body1">Through facilitated workshops, we focused not only on what sustainability means in theory, but above all on how to translate it into everyday practice. Participants were introduced to the core ESG pillars — environmental, social, and governance aspects — and discussed specific examples from the financial sector.</p>
        <p data-i18n="body2">We would like to thank Home Credit for placing their trust in us during the preparation and delivery of this project. We wish all participants that these training sessions serve as a solid foundation for their next steps on the sustainability journey, and we look forward to continuing our collaboration.</p>
    </section>

    <div class="article-conclusion">
        <p data-i18n="ctaText">Is your company preparing for its own ESG journey? We would be happy to help you design educational programmes that prepare your people for the new standards of doing business.</p>
        <a href="mailto:info@learn2grow.cz" class="cta-btn" data-i18n="ctaBtn">Get in touch</a>
    </div>
</article>

<Footer />

</Layout>

<style is:global>
    .article-title {
        font-family: 'DM Sans', sans-serif;
        font-size: 3.5rem;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 1rem;
        line-height: 1.2;
    }
    .article-subtitle {
        font-size: 1.5rem;
        color: var(--text-light);
        font-style: italic;
        margin-bottom: 1.5rem;
    }
    .article-meta { font-size: 0.95rem; color: var(--text-light); }
    @media (max-width: 900px) {
        .article-title { font-size: 2.5rem; }
        .article-subtitle { font-size: 1.2rem; }
    }
</style>

<script>
    import { sharedTranslations } from '../i18n/translations';

const langBtns = document.querySelectorAll('.lang-btn') as NodeListOf<HTMLButtonElement>;
let currentLang: string = localStorage.getItem('language') || 'en';

const translations: Record<string, Record<string, string>> = {
    en: {
        ...sharedTranslations.en,
        articleCategory: 'News',
        articleTitle: 'ESG in Practice: Supporting Clients on Their Sustainability Journey',
        articleDate: 'January 13, 2025',
        articleIntro: 'At learn2grow, we believe that real change within an organization starts with people and their understanding of new challenges. In one of our projects, we became the facilitators on the "Sustainability Journey" for Home Credit and its subsidiaries around the world.',
        body1: 'Through facilitated workshops, we focused not only on what sustainability means in theory, but above all on how to translate it into everyday practice. Participants were introduced to the core ESG pillars — environmental, social, and governance aspects — and discussed specific examples from the financial sector.',
        body2: 'We would like to thank Home Credit for placing their trust in us during the preparation and delivery of this project. We wish all participants that these training sessions serve as a solid foundation for their next steps on the sustainability journey, and we look forward to continuing our collaboration.',
        ctaText: 'Is your company preparing for its own ESG journey? We would be happy to help you design educational programmes that prepare your people for the new standards of doing business.',
        ctaBtn: 'Get in touch',
    },
    cs: {
        ...sharedTranslations.cs,
        articleCategory: 'Aktuality',
        articleTitle: 'ESG v praxi: Pomáháme klientům na cestě k udržitelnosti',
        articleDate: '13. ledna 2025',
        articleIntro: 'V learn2grow věříme, že skutečná změna v organizaci začíná u lidí a jejich pochopení nových výzev. V jednom z našich projektů jsme se stali průvodci na „Sustainability Journey" pro Home Credit a jeho pobočky po celém světě.',
        body1: 'V rámci facilitovaných workshopů jsme se zaměřili nejen na to, co udržitelnost v teorii znamená, ale především na to, jak ji přenést do každodenní praxe. Účastníci se seznámili se základními pilíři ESG — environmentálními, sociálními a governance aspekty — a diskutovali o konkrétních příkladech z finančního sektoru.',
        body2: 'Rádi bychom poděkovali Home Credit za důvěru při přípravě a realizaci tohoto projektu. Přejeme všem účastníkům, aby tato školení sloužila jako pevný základ pro jejich další kroky na cestě k udržitelnosti, a těšíme se na pokračování spolupráce.',
        ctaText: 'Připravuje se i vaše firma na vlastní ESG cestu? Rádi vám pomůžeme navrhnout vzdělávací programy, které vaše lidi připraví na nové standardy podnikání.',
        ctaBtn: 'Kontaktujte nás',
    }
};

function setLanguage(lang: string): void {
    currentLang = lang;
    localStorage.setItem('language', lang);
    document.documentElement.lang = lang === 'cs' ? 'cs' : 'en';
    langBtns.forEach(btn => btn.classList.toggle('active', btn.dataset.lang === lang));
    const t = translations[lang];
    document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n')!;
        if (t[key]) el.innerHTML = t[key];
    });
}
langBtns.forEach(btn => btn.addEventListener('click', () => setLanguage(btn.dataset.lang!)));
setLanguage(currentLang);

window.addEventListener('scroll', () => {
    document.querySelector('nav')!.classList.toggle('scrolled', window.scrollY > 50);
});

</script>
