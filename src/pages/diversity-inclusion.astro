---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/globals.css';
---

<Layout title="Diversity &amp; Inclusion Project - learn2grow">

<Nav />

<!-- Article Header -->
<header class="article-header">
    <span class="article-category-badge" data-i18n="articleCategory">News</span>
    <h1 class="article-title" data-i18n="articleTitle">Diversity &amp; Inclusion Project</h1>
    <p class="article-meta" data-i18n="articleDate">December 8, 2021</p>
</header>

<!-- Article Content -->
<article class="article-content">
    <a href="/insights" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"></path>
        </svg>
        <span data-i18n="backToInsights">Back to Insights</span>
    </a>

    <div class="article-image-block">
        <img loading="lazy" src="/images/article7.jpg" alt="Diversity and Inclusion visual maps workshop" />
    </div>

    <div class="article-intro">
        <p data-i18n="articleIntro">We completed another visual maps project, this time on the topic of diversity and inclusion for Home Credit International — helping teams across the organisation better understand and work with one of the most complex and important themes in modern business.</p>
    </div>

    <section class="article-section">
        <p data-i18n="body1">Diversity and inclusion is inherently complex territory. Conversations about it can easily become abstract or uncomfortable without the right scaffolding. Visual maps help participants ground the discussion in shared language and concrete thinking — making it easier to explore difficult topics together with openness rather than defensiveness.</p>
        <p data-i18n="body2">The workshop was facilitated by Lucie Melicharová, who brings extensive experience with similar projects across industries and cultures. Through guided exploration of the visual maps, participants were able to map their own understanding of D&I and begin building a shared framework for their organisation's journey.</p>
        <p data-i18n="body3">Participants now have a diversity and inclusion map and are ready to take the next steps on their organisational journey. We believe that meaningful change on these topics starts not with policy, but with understanding — and that understanding starts with conversations like these.</p>
    </section>

    <div class="article-conclusion">
        <p data-i18n="ctaText">Is your company working on its own diversity and inclusion journey? We would be happy to help — reach out and let's talk.</p>
        <a href="mailto:info@learn2grow.cz" class="cta-btn" data-i18n="ctaBtn">Get in touch</a>
    </div>
</article>

<Footer />

</Layout>

<style is:global>
    .article-title {
        font-family: 'DM Sans', sans-serif;
        font-size: 3.5rem;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 1rem;
        line-height: 1.2;
    }
    .article-subtitle {
        font-size: 1.5rem;
        color: var(--text-light);
        font-style: italic;
        margin-bottom: 1.5rem;
    }
    .article-meta { font-size: 0.95rem; color: var(--text-light); }
    @media (max-width: 900px) {
        .article-title { font-size: 2.5rem; }
        .article-subtitle { font-size: 1.2rem; }
    }
</style>

<script>
    import { sharedTranslations } from '../i18n/translations';

const langBtns = document.querySelectorAll('.lang-btn') as NodeListOf<HTMLButtonElement>;
let currentLang: string = localStorage.getItem('language') || 'en';

const translations: Record<string, Record<string, string>> = {
    en: {
        ...sharedTranslations.en,
        articleCategory: 'News',
        articleTitle: 'Diversity & Inclusion Project',
        articleDate: 'December 8, 2021',
        articleIntro: 'We completed another visual maps project, this time on the topic of diversity and inclusion for Home Credit International — helping teams across the organisation better understand and work with one of the most complex and important themes in modern business.',
        body1: 'Diversity and inclusion is inherently complex territory. Conversations about it can easily become abstract or uncomfortable without the right scaffolding. Visual maps help participants ground the discussion in shared language and concrete thinking — making it easier to explore difficult topics together with openness rather than defensiveness.',
        body2: 'The workshop was facilitated by Lucie Melicharová, who brings extensive experience with similar projects across industries and cultures. Through guided exploration of the visual maps, participants were able to map their own understanding of D&I and begin building a shared framework for their organisation\'s journey.',
        body3: 'Participants now have a diversity and inclusion map and are ready to take the next steps on their organisational journey. We believe that meaningful change on these topics starts not with policy, but with understanding — and that understanding starts with conversations like these.',
        ctaText: 'Is your company working on its own diversity and inclusion journey? We would be happy to help — reach out and let\'s talk.',
        ctaBtn: 'Get in touch',
    },
    cs: {
        ...sharedTranslations.cs,
        articleCategory: 'Aktuality',
        articleTitle: 'Projekt Diverzita a inkluze',
        articleDate: '8. prosince 2021',
        articleIntro: 'Realizovali jsme další projekt vizuálních map, tentokrát na téma diverzity a inkluze pro společnost Home Credit International — pomáháme týmům napříč organizací lépe porozumět jednomu z nejsložitějších a nejdůležitějších témat moderního byznysu a pracovat s ním.',
        body1: 'Diverzita a inkluze jsou ze své podstaty složitým územím. Rozhovory o nich se mohou bez správného rámce snadno stát abstraktními nebo nepříjemnými. Vizuální mapy pomáhají účastníkům ukotvit diskusi ve sdíleném jazyce a konkrétním myšlení — a usnadňují tak společné prozkoumávání obtížných témat s otevřeností místo obrany.',
        body2: 'Workshop facilitovala Lucie Melicharová, která má bohaté zkušenosti s podobnými projekty napříč odvětvími a kulturami. Prostřednictvím řízeného prozkoumávání vizuálních map byli účastníci schopni zmapovat vlastní chápání D&I a začít budovat sdílený rámec pro cestu jejich organizace.',
        body3: 'Účastníci nyní mají mapu diverzity a inkluze a jsou připraveni na další kroky na své organizační cestě. Věříme, že smysluplná změna v těchto tématech nezačíná politikou, ale porozuměním — a to porozumění začíná právě takovými rozhovory.',
        ctaText: 'Pokud i ve vaší firmě řešíte něco podobného, rádi vám s tím pomůžeme — kontaktujte nás!',
        ctaBtn: 'Kontaktujte nás',
    }
};

function setLanguage(lang: string): void {
    currentLang = lang;
    localStorage.setItem('language', lang);
    document.documentElement.lang = lang === 'cs' ? 'cs' : 'en';
    langBtns.forEach(btn => btn.classList.toggle('active', btn.dataset.lang === lang));
    const t = translations[lang];
    document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n')!;
        if (t[key]) el.innerHTML = t[key];
    });
}
langBtns.forEach(btn => btn.addEventListener('click', () => setLanguage(btn.dataset.lang!)));
setLanguage(currentLang);

window.addEventListener('scroll', () => {
    document.querySelector('nav')!.classList.toggle('scrolled', window.scrollY > 50);
});

</script>
