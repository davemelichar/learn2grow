</section>

<!-- Insights Section -->
<section id="insights" class="section-insights">
    <div class="section-inner">
        <div style="text-align: center; margin-bottom: 4rem;">
            <h2 class="section-title-large" data-i18n="insightsTitle">Insights</h2>
            <div class="orange-bar" style="margin: 0 auto;"></div>
        </div>
        <div class="articles-grid">
            <div class="article-card">
                <div class="article-image" style="background-image: url('/images/article1.jpg');">
                    <span class="category-badge">Articles</span>
                </div>
                <div class="article-body">
                    <p class="article-date">January 26, 2026</p>
                    <h3 class="article-title" data-i18n="article1Title">Leadership Through the Eyes of AI</h3>
                    <p class="article-excerpt" data-i18n="article1Excerpt">AI is taking hold in companies, and managers often have high expectations of AI. But what does AI actually expect from leaders?</p>
                    <a href="/leadership-ai" class="read-more-link" data-i18n="readMore">
                        Read more
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
                    </a>
                </div>
            </div>
            <div class="article-card">
                <div class="article-image" style="background-image: url('/images/article2.jpg');">
                    <span class="category-badge category-badge--primary">News</span>
                </div>
                <div class="article-body">
                    <p class="article-date">December 12, 2025</p>
                    <h3 class="article-title" data-i18n="article2Title">Preparing Leaders for the Era of Physical AI</h3>
