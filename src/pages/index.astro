                <a href="mailto:info@learn2grow.cz" aria-label="Send email to learn2grow" class="social-btn">✉</a>
            </div>
        </div>
    </div>
</footer>

</Layout>

<style is:global>
/* ─── Hero ───────────────────────────────────────────────── */
.hero {
    margin-top: 70px;
    min-height: 65vh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #fff, #fff7ed, #ffedd5);
    overflow: hidden;
    position: relative;
}
.hero::before {
    content: "";
    position: absolute;
    top: -30%; right: -10%;
    width: 120%; height: 160%;
    background: radial-gradient(circle, rgba(255,140,0,0.08) 0%, transparent 70%);
    animation: float 20s ease-in-out infinite;
}
@keyframes float {
    0%, 100% { transform: translate(0) rotate(0); }
    33%       { transform: translate(30px, -30px) rotate(5deg); }
    66%       { transform: translate(-20px, 20px) rotate(-5deg); }
}
.hero-slider {
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
    padding: 6rem 2rem;
    z-index: 1;
    min-height: 75vh;
    width: 100%;
}
.hero-slide {
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeInUp 0.8s ease-out;
}
.hero-slide-inner {
    display: flex;
    align-items: center;
    gap: 3rem;
    width: 100%;
    padding: 2rem 0;
    flex-direction: row-reverse;
}
.hero-slide-image {
    flex: 0 0 380px;
    max-width: 380px;
}
.hero-slide-image img {
    width: 100%;
    height: auto;
    border-radius: 20px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.08);
}
.hero-slide-content { flex: 1; }
.hero-slide-subheader {
    font-family: 'DM Sans', sans-serif;
    font-size: 3rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 1.5rem;
    line-height: 1.2;
}
