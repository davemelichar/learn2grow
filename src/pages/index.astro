<!-- Footer / Contact -->
<footer id="contact">
    <div class="footer-inner">
        <div class="footer-grid">
            <div>
                <img src="/images/Logo.jpeg" alt="learn2grow" class="footer-logo" />
                <div class="footer-contact">
                    <p><strong>learn2grow s. r. o.</strong></p>
                    <p>Prague, Czech Republic</p>
                    <p>(+420) 773 923 402</p>
                    <p>info@learn2grow.cz</p>
                </div>
            </div>
            <div>
                <h4 class="footer-heading" data-i18n="footerServices">Services</h4>
                <ul class="footer-links">
                    <li><a href="#headhunting" data-i18n="headhuntingTitle">Headhunting</a></li>
                    <li><a href="#hr-consulting" data-i18n="hrTitle">HR Consulting</a></li>
                </ul>
            </div>
            <div>
                <h4 class="footer-heading" data-i18n="footerCompany">Company</h4>
                <ul class="footer-links">
