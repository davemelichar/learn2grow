function setLanguage(lang: string): void {
    currentLang = lang;
    localStorage.setItem('language', lang);
    document.documentElement.lang = lang === 'cs' ? 'cs' : 'en';
    langBtns.forEach(btn => btn.classList.toggle('active', btn.dataset.lang === lang));
    const t = translations[lang];
    document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n')!;
        if (t[key]) el.innerHTML = t[key];
    });
}

langBtns.forEach(btn => btn.addEventListener('click', () => setLanguage(btn.dataset.lang!)));
setLanguage(currentLang);

// Navbar scroll + active section highlight
function updateActiveNav(): void {
    const anchors = document.querySelectorAll<HTMLAnchorElement>('.nav-links a[href^="#"], .nav-links a[href^="/#"]');
    const sections = document.querySelectorAll<HTMLElement>('section[id], footer[id]');
    let active = '';
    const scrollPos = window.scrollY + 150;
    const atBottom = window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 10;
    if (atBottom) {
        active = 'contact';
    } else {
        sections.forEach(s => {
            if (scrollPos >= s.offsetTop && scrollPos < s.offsetTop + s.offsetHeight) active = s.id;
        });
    }
    anchors.forEach(a => {
        const href = a.getAttribute('href')!;
        a.classList.remove('active');
        if (href === `#${active}` || href === `/#${active}`) a.classList.add('active');
    });
}

window.addEventListener('scroll', () => {
    const navbar = document.getElementById('navbar')!;
    navbar.classList.toggle('scrolled', window.scrollY > 50);
    updateActiveNav();

    const btn = document.getElementById('backToTop')!;
    btn.classList.toggle('visible', window.scrollY > 500);
});

// Smooth scroll for anchor links (handles both #section and /#section)
document.querySelectorAll<HTMLAnchorElement>('a[href^="#"], a[href^="/#"]').forEach(a => {
    a.addEventListener('click', function(e) {
        const href = this.getAttribute('href')!;
        const hash = href.startsWith('/#') ? href.slice(1) : href;
        const target = document.querySelector(hash);
        if (target) {
            e.preventDefault();
            const offset = document.getElementById('navbar')!.offsetHeight + 20;
            window.scrollTo({ top: (target as HTMLElement).offsetTop - offset, behavior: 'smooth' });
        }
    });
});

// Back to top
document.getElementById('backToTop')!.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
});
</script>
