---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/globals.css';

const schema = JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'learn2grow',
    url: 'https://learn2grow.cz',
    description: 'Executive Search & Strategic Consulting',
    contactPoint: {
        '@type': 'ContactPoint',
        email: 'info@learn2grow.cz',
        telephone: '+420773923402',
    },
});
---

<Layout title="learn2grow | Executive Search & Strategic Consulting" schema={schema}>

<Nav />

<!-- Hero Section -->
<section class="hero">
    <div class="hero-slider">
        <div class="hero-slide">
            <div class="hero-slide-inner">
                <div class="hero-slide-content">
                    <h2 class="hero-slide-subheader" data-i18n="heroTitle">Executive Search<br />& Strategic<br />Consulting</h2>
                    <p class="hero-slide-text" data-i18n="heroText">We help you identify leaders who move your organization forward. We build on trust and a deep understanding of your needs.</p>
                    <div class="hero-cta-group">
                        <a href="mailto:info@learn2grow.cz?subject=Consulting" class="cta-button" data-i18n="heroCTA">Schedule a consultation</a>
                        <a href="#headhunting" class="cta-button-outline" data-i18n="learnMore">Learn More</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Headhunting Section -->
<section id="headhunting" class="section-white">
    <div class="section-inner">
        <div class="section-header">
            <h2 class="section-title-large" data-i18n="headhuntingTitle">Headhunting</h2>
            <div class="orange-bar"></div>
            <p class="section-lead" data-i18n="executiveSearchText">Executive search starts with a deep understanding of your business, its context, and its leadership needs. We bring in-depth insight into your situation and identify candidates who deliver real, lasting value to your organization. Our work combines direct search with disciplined assessment and a deep understanding of organizational context. All of our consultants bring first-hand corporate leadership experience, enabling sharper judgment and better hiring decisions.</p>
        </div>

        <div class="process-strip">
            <div class="process-step">
                <span class="process-step-num">01</span>
                <div class="process-icon-wrap">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M21 21L16.514 16.506M19 10.5C19 15.194 15.194 19 10.5 19C5.806 19 2 15.194 2 10.5C2 5.806 5.806 2 10.5 2C15.194 2 19 5.806 19 10.5Z" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </div>
                <h4 class="process-step-title" data-i18n="processStep1Title">Understand</h4>
                <p class="process-step-desc" data-i18n="processStep1Desc">Deep dive into your business, culture, and leadership needs before any search begins.</p>
            </div>
            <div class="process-connector">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="#F97316" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            </div>
            <div class="process-step">
                <span class="process-step-num">02</span>
                <div class="process-icon-wrap">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M17 21V19C17 17.9391 16.5786 16.9217 15.8284 16.1716C15.0783 15.4214 14.0609 15 13 15H5C3.93913 15 2.92172 15.4214 2.17157 16.1716C1.42143 16.9217 1 17.9391 1 19V21M9 11C11.2091 11 13 9.20914 13 7C13 4.79086 11.2091 3 9 3C6.79086 3 5 4.79086 5 7C5 9.20914 6.79086 11 9 11ZM23 21V19C22.9993 18.1137 22.7044 17.2528 22.1614 16.5523C21.6184 15.8519 20.8581 15.3516 20 15.13M16 3.13C16.8604 3.3503 17.623 3.8507 18.1676 4.55231C18.7122 5.25392 19.0078 6.11683 19.0078 7.005C19.0078 7.89317 18.7122 8.75608 18.1676 9.45769C17.623 10.1593 16.8604 10.6597 16 10.88" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </div>
                <h4 class="process-step-title" data-i18n="processStep2Title">Search</h4>
                <p class="process-step-desc" data-i18n="processStep2Desc">Direct market search combined with disciplined, rigorous candidate assessment.</p>
            </div>
            <div class="process-connector">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="#F97316" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            </div>
            <div class="process-step">
                <span class="process-step-num">03</span>
                <div class="process-icon-wrap">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M22 11.08V12C21.9988 14.1564 21.3005 16.2547 20.0093 17.9818C18.7182 19.709 16.9033 20.9725 14.8354 21.5839C12.7674 22.1953 10.5573 22.1219 8.53447 21.3746C6.51168 20.6273 4.78465 19.2461 3.61096 17.4371C2.43727 15.628 1.87979 13.4881 2.02168 11.3363C2.16356 9.18455 2.99721 7.13631 4.39828 5.49706C5.79935 3.85781 7.69279 2.71537 9.79619 2.24013C11.8996 1.7649 14.1003 1.98232 16.07 2.85999M22 4L12 14.01L9 11.01" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </div>
                <h4 class="process-step-title" data-i18n="processStep3Title">Place</h4>
                <p class="process-step-desc" data-i18n="processStep3Desc">Leaders who fit your culture and deliver lasting value to your organization.</p>
            </div>
        </div>

        <div class="quality-box">
            <div class="quality-header">
                <div class="quality-header-inner">
                    <h2 class="quality-title" data-i18n="qualityTitle">Our Approach</h2>
                    <div class="quality-header-rule"></div>
                </div>
                <div class="quality-header-icon"></div>
            </div>
            <div class="quality-body">
                <p class="quality-text" data-i18n="qualityText1">Quality, context, and long-term impact guide everything we do. We do not evaluate candidates in isolation — we assess leadership potential, cultural alignment, and the ability to contribute meaningfully to your business over time. The goal is not just to fill a role, but to strengthen your organization.</p>
                <p class="quality-text quality-text--label" data-i18n="qualityText2">We typically support clients in situations where hiring is complex, sensitive, or strategically critical, including when:</p>
                <ul class="bullet-list">
                    <li><span class="bullet-icon"><svg width="10" height="10" viewBox="0 0 10 10" fill="#F97316"><polygon points="5,0 10,5 5,10 0,5"/></svg></span><p data-i18n="bullet1">a confidential or sensitive position needs to be filled</p></li>
                    <li><span class="bullet-icon"><svg width="10" height="10" viewBox="0 0 10 10" fill="#F97316"><polygon points="5,0 10,5 5,10 0,5"/></svg></span><p data-i18n="bullet2">the organization is growing rapidly and internal HR capacity is stretched</p></li>
                    <li><span class="bullet-icon"><svg width="10" height="10" viewBox="0 0 10 10" fill="#F97316"><polygon points="5,0 10,5 5,10 0,5"/></svg></span><p data-i18n="bullet3">a key role remains unfilled for an extended period</p></li>
                    <li><span class="bullet-icon"><svg width="10" height="10" viewBox="0 0 10 10" fill="#F97316"><polygon points="5,0 10,5 5,10 0,5"/></svg></span><p data-i18n="bullet4">the required expertise is scarce in the market</p></li>
                </ul>
            </div>
        </div>

        <div class="section-cta">
            <a href="mailto:info@learn2grow.cz?subject=Headhunting" class="cta-orange" data-i18n="headhuntingCTA">
                Start a Search
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            </a>
        </div>
    </div>
</section>

<!-- HR Consulting Section -->
<section id="hr-consulting" class="section-surface section-with-glow">
    <div class="section-inner">
        <div class="section-header">
            <h2 class="section-title-large" data-i18n="hrTitle">HR Consulting</h2>
            <div class="orange-bar"></div>
            <p class="section-lead" data-i18n="hrText">Our passion is to work with companies and their leaders to grow their human capital. We help companies implement solid HR processes such as performance management, competency models, assessment centers, people development, 360-degree feedback, and sales force assessment and optimization.</p>
        </div>

        <div class="approach-strip">
            <div class="approach-pillar">
                <div class="approach-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M17 21V19C17 17.9391 16.5786 16.9217 15.8284 16.1716C15.0783 15.4214 14.0609 15 13 15H5C3.93913 15 2.92172 15.4214 2.17157 16.1716C1.42143 16.9217 1 17.9391 1 19V21M9 11C11.2091 11 13 9.20914 13 7C13 4.79086 11.2091 3 9 3C6.79086 3 5 4.79086 5 7C5 9.20914 6.79086 11 9 11ZM23 21V19C22.9993 18.1137 22.7044 17.2528 22.1614 16.5523C21.6184 15.8519 20.8581 15.3516 20 15.13M16 3.13C16.8604 3.3503 17.623 3.8507 18.1676 4.55231C18.7122 5.25392 19.0078 6.11683 19.0078 7.005C19.0078 7.89317 18.7122 8.75608 18.1676 9.45769C17.623 10.1593 16.8604 10.6597 16 10.88" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </div>
                <div>
                    <h4 class="approach-pillar-title" data-i18n="pillar1Title">People-First</h4>
                    <p class="approach-pillar-text" data-i18n="pillar1Text">Every solution starts with understanding people, not just processes.</p>
                </div>
            </div>
            <div class="approach-divider"></div>
            <div class="approach-pillar">
                <div class="approach-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M18 20V10M12 20V4M6 20V14" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </div>
                <div>
                    <h4 class="approach-pillar-title" data-i18n="pillar2Title">Evidence-Based</h4>
                    <p class="approach-pillar-text" data-i18n="pillar2Text">Decisions grounded in data, diagnostics, and deep organizational insight.</p>
                </div>
            </div>
            <div class="approach-divider"></div>
            <div class="approach-pillar">
                <div class="approach-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M22 7L13.5 15.5L8.5 10.5L2 17M22 7H15M22 7V14" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </div>
                <div>
                    <h4 class="approach-pillar-title" data-i18n="pillar3Title">Long-Term Focus</h4>
                    <p class="approach-pillar-text" data-i18n="pillar3Text">We design for sustainable results, not quick fixes.</p>
                </div>
            </div>
        </div>

        <div class="white-card">
            <div class="card-dark-header">
                <h2 class="card-title" data-i18n="buildingTitle">Building Strong People Systems</h2>
                <div class="card-header-rule"></div>
                <div class="card-header-icon"></div>
            </div>
            <div class="card-body">
                <p class="card-text" data-i18n="buildingText1">We support organizations in designing, implementing, and optimizing core HR processes that create clarity, consistency, and long-term impact. Our consulting work is practical, business-oriented, and closely aligned with leadership priorities. Our engagements are focused on enabling better leadership decisions, stronger teams, and sustainable organizational growth — not just short-term fixes.</p>

                <p class="expertise-label" data-i18n="buildingText2">Our areas of expertise include:</p>
                <div class="expertise-grid">
                    <div class="expertise-item">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                        <span data-i18n="expertise1">Performance management systems</span>
                    </div>
                    <div class="expertise-item">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                        <span data-i18n="expertise2">Competency and leadership models</span>
                    </div>
                    <div class="expertise-item">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                        <span data-i18n="expertise3">Assessment centers and talent diagnostics</span>
                    </div>
                    <div class="expertise-item">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                        <span data-i18n="expertise4">People development programs</span>
                    </div>
                    <div class="expertise-item">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                        <span data-i18n="expertise5">360-degree feedback</span>
                    </div>
                    <div class="expertise-item">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                        <span data-i18n="expertise6">Assessment and optimization of sales forces</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="section-cta">
            <a href="mailto:info@learn2grow.cz?subject=HR Consulting" class="cta-orange" data-i18n="hrCTA">
                Get in Touch
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            </a>
        </div>
    </div>
</section>

<!-- About Us Section -->
<section id="about" class="section-white">
    <div class="section-inner">
        <div class="section-header">
            <h2 class="section-title-large" data-i18n="aboutTitle">About Us</h2>
            <div class="orange-bar"></div>
            <p class="section-lead" data-i18n="approachText">We bring inspiration, insights and great commitment into our projects to help you become a better business. We pride in designing solutions that are both sustainable and socially responsible.</p>
        </div>

        <div class="why-stats-layout">
            <div class="why-feature">
                <div class="why-feature-header">
                    <p class="why-feature-eyebrow" data-i18n="whyTitle">Why learn2grow</p>
                    <div class="why-feature-rule"></div>
                    <div class="why-feature-icon"></div>
                </div>
                <div class="why-feature-content">
                    <h3 class="why-feature-heading" data-i18n="whyHeadline">Extraordinary results, made sustainable.</h3>
                    <p class="why-feature-body" data-i18n="whyText">We partner with you to build performance-oriented organizations and to find and develop leaders at all levels of your organization. We help you build a company culture that makes extraordinary results sustainable by focusing on values, results and competencies.</p>
                </div>
            </div>

            <div class="stats-row">
                <div class="stat-block">
                    <div class="stat-number">250<span class="stat-plus">+</span></div>
                    <p class="stat-label" data-i18n="stat1Label">Clients across Europe</p>
                </div>
                <div class="stat-block">
                    <div class="stat-number">600<span class="stat-plus">+</span></div>
                    <p class="stat-label" data-i18n="stat2Label">Client projects delivered</p>
                </div>
                <div class="stat-block">
                    <div class="stat-number">20<span class="stat-plus">+</span></div>
                    <p class="stat-label" data-i18n="stat3Label">Years in business</p>
                </div>
            </div>
        </div>

        <!-- Our People -->
        <div id="team" class="team-section">
            <h3 class="subsection-title" data-i18n="teamTitle">Our People</h3>
            <div class="team-grid">
                <div class="team-member">
                    <a href="https://www.linkedin.com/in/lucie-melicharova-0267aa3/" target="_blank" rel="noopener noreferrer" aria-label="View Lucie Melicharová's LinkedIn profile" class="team-photo-link">
                        <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=200&h=200&fit=crop" alt="Lucie Melicharová" loading="lazy" class="team-photo" />
                        <div class="linkedin-overlay">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="rgba(28, 25, 23, 0.8)"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
                        </div>
                    </a>
                    <div>
                        <h4 class="member-name">Lucie Melicharová</h4>
                        <p class="member-role">Managing Director</p>
                    </div>
                </div>
                <div class="team-member">
                    <a href="https://www.linkedin.com/in/amandabence/" target="_blank" rel="noopener noreferrer" aria-label="View Amanda Bence's LinkedIn profile" class="team-photo-link">
                        <img src="https://images.unsplash.com/photo-1580489944761-15a19d654956?w=200&h=200&fit=crop" alt="Amanda Bence" loading="lazy" class="team-photo" />
                        <div class="linkedin-overlay">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="rgba(28, 25, 23, 0.8)"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
                        </div>
                    </a>
                    <div>
                        <h4 class="member-name">Amanda Bence</h4>
                        <p class="member-role">Partner, Executive Search</p>
                    </div>
                </div>
                <div class="team-member">
                    <a href="https://www.linkedin.com/in/monika-vale%C5%A1ov%C3%A1-26889553/" target="_blank" rel="noopener noreferrer" aria-label="View Monika Valešová's LinkedIn profile" class="team-photo-link">
                        <img src="https://images.unsplash.com/photo-1598550874175-4d0ef436c909?w=200&h=200&fit=crop" alt="Monika Valešová" loading="lazy" class="team-photo" />
                        <div class="linkedin-overlay">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="rgba(28, 25, 23, 0.8)"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
                        </div>
                    </a>
                    <div>
                        <h4 class="member-name">Monika Valešová</h4>
                        <p class="member-role">Consultant</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Testimonials -->
        <div class="testimonials-section">
            <h3 class="subsection-title" data-i18n="testimonialTitle">What Our Clients Say</h3>
            <div class="testimonials-grid">
                <div class="testimonial-card">
                    <div class="quote-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--orange)"><path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"></path></svg>
                    </div>
                    <p class="testimonial-text" data-i18n="testimonial1">We use innovative solutions from learn2grow portfolio to develop and grow our employees and our business.</p>
                    <div class="testimonial-author-block">
                        <p class="testimonial-author">CEO</p>
                        <p class="testimonial-company">Financial institution</p>
                    </div>
                </div>
                <div class="testimonial-card">
                    <div class="quote-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--orange)"><path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"></path></svg>
                    </div>
                    <p class="testimonial-text" data-i18n="testimonial2">learn2grow is a long-term, high quality partner in hiring into important positions at our company.</p>
                    <div class="testimonial-author-block">
                        <p class="testimonial-author">HR Director</p>
                        <p class="testimonial-company">International Corporation</p>
                    </div>
                </div>
