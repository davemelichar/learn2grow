---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/globals.css';
---

<Layout
    title="Privacy Policy – learn2grow"
    description="Privacy Policy of learn2grow s.r.o. – how we collect, use, and protect your personal data in accordance with GDPR."
>
    <Nav />

    <!-- Page Header -->
    <header class="privacy-header">
        <div class="privacy-header-inner">
            <p class="privacy-eyebrow">Legal</p>
            <h1 class="privacy-title">Privacy Policy</h1>
            <p class="privacy-updated">learn2grow s.r.o.</p>
        </div>
    </header>

    <!-- Privacy Content -->
    <div class="privacy-wrap">
        <a href="/" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"></path></svg>
            Back to Home
        </a>

        <!-- Company Info -->
        <div class="privacy-company-card">
            <div class="privacy-company-row">
                <div>
                    <p class="privacy-company-name">learn2grow s.r.o.</p>
                    <p>Company ID (IČO): 26733765</p>
                    <p>K Oboře 181, 252 42 Jesenice – Osnice, Czech Republic</p>
                    <p>Registered in the Commercial Register maintained by the Municipal Court in Prague, Section C, Insert 90343</p>
                </div>
                <div class="privacy-company-contact">
                    <p><a href="mailto:info@learn2grow.cz">info@learn2grow.cz</a></p>
                    <p>+420 773 923 402</p>
                </div>
            </div>
            <p class="privacy-controller-note">
                learn2grow s.r.o. is the data controller within the meaning of Article 4(7) of Regulation (EU) 2016/679 (General Data Protection Regulation –
                "GDPR").
            </p>
        </div>

        <!-- Legal Framework -->
        <section class="privacy-section">
            <h2>Legal Framework</h2>
            <p>We process personal data in accordance with:</p>
            <ul>
                <li>Regulation (EU) 2016/679 (GDPR)</li>
                <li>Act No. 110/2019 Coll., on the Processing of Personal Data</li>
                <li>Other applicable Czech legislation</li>
            </ul>
        </section>

        <!-- Scope of Services -->
        <section class="privacy-section">
            <h2>Scope of Our Services</h2>
            <p>We provide professional services in the areas of:</p>
            <ul>
                <li>Executive Search and Leadership Recruitment</li>
                <li>Leadership Consulting</li>
                <li>Learning and Development Solutions</li>
            </ul>
        </section>

        <!-- Confidentiality -->
        <section class="privacy-section">
            <h2>Executive Search Confidentiality</h2>
            <p>
                Due to the confidential nature of executive search assignments, we process personal data with strict professional discretion. Candidate
                information is shared with clients only where relevant for a specific search mandate and in accordance with applicable legal grounds.
            </p>
        </section>

        <!-- Categories -->
        <section class="privacy-section">
            <h2>Categories and Sources of Personal Data</h2>
            <p>We may receive personal data:</p>
            <ul>
                <li>Directly from the data subject</li>
                <li>From our clients in the context of a search assignment</li>
                <li>From publicly available professional sources (e.g., LinkedIn, corporate websites)</li>
            </ul>

            <h3>Executive Search Candidates</h3>
            <p>When you apply for a role or are approached as a potential candidate, we may process:</p>
            <ul>
                <li>Name and surname</li>
                <li>Contact details (email, phone)</li>
                <li>Education and qualifications</li>
                <li>Employment history and professional experience</li>
                <li>CV and motivation letter</li>
                <li>References (if provided)</li>
                <li>Salary expectations (if voluntarily shared)</li>
                <li>Date of birth, photo, nationality (if included in CV)</li>
            </ul>
            <p>We do not request copies of identity documents, ID numbers, or other unnecessary personal data.</p>
            <p>
                In certain executive search assignments, we may proactively approach potential candidates based on publicly available professional information.
                In such cases, personal data is processed based on our legitimate interest in identifying suitable candidates for leadership roles. Candidates
                are informed at the time of first contact about the processing of their personal data.
            </p>

            <h3>Client and Business Partner Data</h3>
            <ul>
                <li>Name</li>
                <li>Position</li>
                <li>Company</li>
                <li>Business contact details</li>
            </ul>

            <h3>Learning &amp; Development Participants</h3>
            <p>For learning portals or feedback systems:</p>
            <ul>
                <li>Name</li>
                <li>Company</li>
                <li>Email address</li>
                <li>Participation history</li>
                <li>Feedback responses</li>
            </ul>

            <h3>Website Visitors</h3>
            <p>When visiting our website, we may process:</p>
            <ul>
                <li>IP address</li>
                <li>Cookies</li>
                <li>Website usage data</li>
            </ul>
            <p>Details are provided in the Cookies section below.</p>
        </section>

        <!-- Legal Basis -->
        <section class="privacy-section">
            <h2>Legal Basis for Processing</h2>
            <p>We process personal data based on the following legal grounds:</p>

            <div class="privacy-basis-grid">
                <div class="privacy-basis-card">
                    <h3>Executive Search</h3>
                    <ul>
                        <li>Article 6(1)(b) GDPR – taking steps prior to entering into a contract</li>
                        <li>Article 6(1)(f) GDPR – legitimate interest in matching candidates with client mandates</li>
                        <li>Article 6(1)(a) GDPR – consent (for inclusion in talent pool beyond a specific recruitment process)</li>
                    </ul>
                </div>
                <div class="privacy-basis-card">
                    <h3>Clients &amp; Business Partners</h3>
                    <ul>
                        <li>Article 6(1)(b) GDPR – contract performance</li>
                        <li>Article 6(1)(f) GDPR – legitimate interest in business communication</li>
                    </ul>
                </div>
                <div class="privacy-basis-card">
                    <h3>Learning &amp; Development Services</h3>
                    <ul>
                        <li>Article 6(1)(b) GDPR – contract performance</li>
                        <li>Article 6(1)(f) GDPR – legitimate interest in service delivery</li>
                    </ul>
                </div>
                <div class="privacy-basis-card">
                    <h3>Legal &amp; Accounting Obligations</h3>
                    <ul>
                        <li>Article 6(1)(c) GDPR – compliance with legal obligations</li>
                    </ul>
                </div>
                <div class="privacy-basis-card">
                    <h3>Website Analytics</h3>
                    <ul>
                        <li>Article 6(1)(a) GDPR – consent (for non-essential analytical cookies)</li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- Purpose -->
        <section class="privacy-section">
            <h2>Purpose of Processing</h2>
            <p>We process personal data for the following purposes:</p>
            <ul>
                <li>Conducting executive search and recruitment projects</li>
                <li>Identifying and evaluating suitable candidates</li>
                <li>Maintaining a talent pool (where consent is provided)</li>
                <li>Providing leadership consulting services</li>
                <li>Delivering learning and development projects</li>
                <li>Managing contractual and business relationships</li>
                <li>Complying with legal obligations</li>
                <li>Improving website functionality and user experience</li>
            </ul>
        </section>

        <!-- Retention -->
        <section class="privacy-section">
            <h2>Data Retention</h2>
            <p>Personal data is retained only for as long as necessary:</p>
            <div class="privacy-table-wrap">
                <table class="privacy-table">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th>Retention Period</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Candidates (active recruitment process)</td>
                            <td>Duration of the specific recruitment assignment</td>
                        </tr>
                        <tr>
                            <td>Talent pool (with consent)</td>
                            <td>Typically 2 years, or until consent is withdrawn</td>
                        </tr>
                        <tr>
                            <td>Client and contractual data</td>
                            <td>Duration of relationship + statutory retention period</td>
                        </tr>
                        <tr>
                            <td>Accounting data</td>
                            <td>In accordance with Czech law (typically 10 years)</td>
                        </tr>
                        <tr>
                            <td>Website analytics data</td>
                            <td>According to analytics provider retention settings</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <p>After expiration of the relevant retention period, personal data is securely deleted or anonymized.</p>
        </section>

        <!-- Recipients -->
        <section class="privacy-section">
            <h2>Recipients and Processors</h2>
            <p>We may share personal data with trusted service providers, including:</p>
            <ul>
                <li>IT and hosting providers</li>
                <li>Email and cloud service providers</li>
                <li>Analytics providers (e.g., Google Analytics)</li>
                <li>Learning platform providers</li>
                <li>Legal and accounting advisors</li>
            </ul>
            <p>All processors are contractually bound to comply with GDPR and process personal data only in accordance with our instructions.</p>
        </section>

        <!-- International Transfers -->
        <section class="privacy-section">
            <h2>International Data Transfers</h2>
            <p>
                Some of our service providers (e.g., Google) may process personal data outside the European Economic Area (EEA). Where personal data is
                transferred outside the EEA, such transfer is carried out only where appropriate safeguards are in place, including:
            </p>
            <ul>
                <li>Standard Contractual Clauses approved by the European Commission</li>
                <li>Transfers to countries recognized as providing an adequate level of data protection</li>
            </ul>
        </section>

        <!-- Security -->
        <section class="privacy-section">
            <h2>Data Security</h2>
            <p>
                We implement appropriate technical and organizational measures to ensure personal data is protected against unauthorized access, loss, misuse,
                alteration, or disclosure.
            </p>
            <p>Access to personal data is limited to authorized personnel and trusted partners who are bound by confidentiality obligations.</p>
        </section>

        <!-- Cookies -->
        <section class="privacy-section">
            <h2>Cookies</h2>
            <p>Our website uses cookies to:</p>
            <ul>
                <li>Ensure proper website functionality</li>
                <li>Analyse website traffic</li>
                <li>Improve user experience</li>
            </ul>
            <p>
                We use Google Analytics for statistical analysis of website traffic. Where required by law, analytical cookies are used only on the basis of
                user consent.
            </p>
            <p>You may:</p>
            <ul>
                <li>Accept or reject non-essential cookies via the cookie banner</li>
                <li>Adjust your browser settings to control cookie storage</li>
            </ul>
            <p>
                More information about Google's privacy practices is available at: <a
                    href="https://policies.google.com/privacy"
                    target="_blank"
                    rel="noopener noreferrer">policies.google.com/privacy</a
                >
            </p>
        </section>

        <!-- Rights -->
        <section class="privacy-section">
            <h2>Your Rights</h2>
            <p>Under GDPR, you have the right to:</p>
            <ul>
                <li>Access your personal data</li>
                <li>Request rectification of inaccurate data</li>
                <li>Request erasure ("right to be forgotten")</li>
                <li>Request restriction of processing</li>
                <li>Object to processing</li>
                <li>Data portability</li>
                <li>Withdraw consent at any time (where processing is based on consent)</li>
                <li>Lodge a complaint with the supervisory authority</li>
            </ul>
            <div class="privacy-authority-box">
                <p class="privacy-authority-label">Supervisory authority in the Czech Republic</p>
                <p><strong>Úřad pro ochranu osobních údajů</strong></p>
                <p><a href="https://www.uoou.cz" target="_blank" rel="noopener noreferrer">www.uoou.cz</a></p>
            </div>
            <p>To exercise your rights, please contact: <a href="mailto:info@learn2grow.cz">info@learn2grow.cz</a></p>
        </section>

        <!-- Automated Decision-Making -->
        <section class="privacy-section">
            <h2>Automated Decision-Making</h2>
            <p>We do not conduct automated decision-making or profiling within the meaning of Article 22 GDPR.</p>
        </section>

        <!-- Changes -->
        <section class="privacy-section">
            <h2>Changes to This Policy</h2>
            <p>We may update this Privacy Policy from time to time. The current version will always be published on our website.</p>
        </section>
    </div>

    <Footer />
</Layout>

<style is:global>
    /* ─── Privacy Header ──────────────────────────────────────── */
    .privacy-header {
        margin-top: 70px;
        background: var(--primary);
        padding: 5rem 2rem 4rem;
        position: relative;
        overflow: hidden;
    }
    .privacy-header::after {
        content: '';
        position: absolute;
        bottom: -80px;
        right: -80px;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(249, 115, 22, 0.12) 0%, transparent 70%);
        pointer-events: none;
    }
    .privacy-header-inner {
        max-width: 860px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }
    .privacy-eyebrow {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--orange);
        margin-bottom: 1rem;
    }
    .privacy-title {
        font-family: 'DM Sans', sans-serif;
        font-size: 3.5rem;
        font-weight: 800;
        color: #fff;
        line-height: 1.15;
        margin-bottom: 0.75rem;
    }
    .privacy-updated {
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.45);
    }

    /* ─── Privacy Content ─────────────────────────────────────── */
    .privacy-wrap {
        max-width: 860px;
        margin: 0 auto;
        padding: 4rem 2rem 6rem;
    }
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--orange);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        margin-bottom: 3rem;
        transition: gap 0.3s ease;
    }
    .back-link:hover {
        gap: 0.75rem;
    }

    /* Company card */
    .privacy-company-card {
        background: var(--surface);
        border-left: 3px solid var(--orange);
        padding: 2rem 2.5rem;
        margin-bottom: 3rem;
    }
    .privacy-company-row {
        display: flex;
        gap: 3rem;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }
    .privacy-company-name {
        font-family: 'DM Sans', sans-serif;
        font-weight: 700;
        color: var(--primary);
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
    }
    .privacy-company-card p {
        font-size: 0.92rem;
        color: var(--text);
        line-height: 1.7;
        margin-bottom: 0.25rem;
    }
    .privacy-company-contact {
        text-align: right;
    }
    .privacy-company-contact a {
        color: var(--orange);
        text-decoration: none;
    }
    .privacy-controller-note {
        font-size: 0.92rem;
        color: var(--text-light);
        line-height: 1.7;
        padding-top: 1.25rem;
        border-top: 1px solid var(--border);
        margin-bottom: 0 !important;
    }

    /* Sections */
    .privacy-section {
        margin-bottom: 3rem;
        padding-bottom: 3rem;
        border-bottom: 1px solid var(--border);
    }
    .privacy-section:last-child {
        border-bottom: none;
    }
    .privacy-section h2 {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 1.25rem;
    }
    .privacy-section h3 {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--primary);
        margin: 2rem 0 0.75rem;
    }
    .privacy-section p {
        font-size: 1rem;
        line-height: 1.8;
        color: var(--text);
        margin-bottom: 1rem;
    }
    .privacy-section a {
        color: var(--orange);
        text-decoration: none;
    }
    .privacy-section a:hover {
        text-decoration: underline;
    }
    .privacy-section ul {
        list-style: none;
        padding: 0;
        margin: 0.5rem 0 1rem;
    }
    .privacy-section ul li {
        font-size: 1rem;
        line-height: 1.8;
        color: var(--text);
        padding-left: 1.5rem;
        position: relative;
        margin-bottom: 0.4rem;
    }
    .privacy-section ul li::before {
        content: '–';
        position: absolute;
        left: 0;
        color: var(--orange);
        font-weight: 700;
    }

    /* Legal basis grid */
    .privacy-basis-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.25rem;
        margin-top: 1.25rem;
    }
    .privacy-basis-card {
        background: var(--surface);
        padding: 1.5rem;
        border-top: 2px solid var(--orange);
    }
    .privacy-basis-card h3 {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--primary);
        margin: 0 0 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .privacy-basis-card ul {
        margin: 0;
    }
    .privacy-basis-card ul li {
        font-size: 0.88rem;
    }

    /* Retention table */
    .privacy-table-wrap {
        overflow-x: auto;
        margin: 1.25rem 0;
    }
    .privacy-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95rem;
    }
    .privacy-table th {
        background: var(--primary);
        color: #fff;
        padding: 0.85rem 1.25rem;
        text-align: left;
        font-family: 'DM Sans', sans-serif;
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
    }
    .privacy-table td {
        padding: 0.85rem 1.25rem;
        color: var(--text);
        border-bottom: 1px solid var(--border);
        line-height: 1.6;
    }
    .privacy-table tr:nth-child(even) td {
        background: var(--surface);
    }

    /* Supervisory authority box */
    .privacy-authority-box {
        background: var(--surface);
        border-left: 3px solid var(--orange);
        padding: 1.25rem 1.5rem;
        margin: 1.25rem 0;
    }
    .privacy-authority-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--orange);
        margin-bottom: 0.5rem !important;
    }
    .privacy-authority-box p {
        margin-bottom: 0.25rem !important;
    }
    .privacy-authority-box a {
        color: var(--orange);
    }

    /* Responsive */
    @media (max-width: 768px) {
        .privacy-title {
            font-size: 2.5rem;
        }
        .privacy-basis-grid {
            grid-template-columns: 1fr;
        }
        .privacy-company-row {
            flex-direction: column;
            gap: 1rem;
        }
        .privacy-company-contact {
            text-align: left;
        }
    }
</style>

<script>
    import { sharedTranslations } from '../i18n/translations';

    // Navbar scroll
    window.addEventListener('scroll', () => {
        const navbar = document.getElementById('navbar');
        if (navbar) navbar.classList.toggle('scrolled', window.scrollY > 50);
    });
</script>
