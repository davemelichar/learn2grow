        <script>
            // Language toggle functionality
            const langBtns = document.querySelectorAll('.lang-btn');
            let currentLang = localStorage.getItem('language') || 'en';

            const translations = {
                en: {
                    navHeadhunting: 'HEADHUNTING',
                    navHRConsulting: 'HR CONSULTING',
                    navAboutUs: 'ABOUT US',
                    navInsights: 'INSIGHTS',
                    navContact: 'CONTACT',
                    categoryBadge: 'News',
                    articleTitle: 'Discussion with the students of the University of Connecticut School of Business',
                    articleDate: 'March 30, 2022',
                    backLink: 'Back to Insights',
                    intro: 'In March, Lucie Melicharova was a guest speaker of The Executive MBA at the University of Connecticut School of Business, in a session on Well-being in the Workplace, where she discussed the current trends and impact of recent events on employee well-being.',
                    section1Title: 'Well-being in the Workplace',
                    section1Para1:
                        'The main points of the discussion were the concept of well-being, its evolution in the workplace, and how well-being has been affected recently in the disrupted world, both by COVID and the current war in the Ukraine.',
                    donationNote:
                        '🇺🇦 Lucie Melicharova waived her seminar fee in favor of a donation to the People in Need Foundation for the SOS Ukraine project.',
                    footerServices: 'Services',
                    headhuntingTitle: 'Headhunting',
                    hrTitle: 'HR Consulting',
                    footerCompany: 'Company',
                    footerAbout: 'About Us',
                    footerTeam: 'Team',
                    footerInsights: 'Insights',
                    privacyText: 'We respect high standards of privacy protection. Read more about our',
                    privacyLink: 'Privacy Policy and Cookie Statement',
                    copyright: 'Copyright © 2002–2026 learn2grow'
                },
                cs: {
                    navHeadhunting: 'HEADHUNTING',
                    navHRConsulting: 'HR PORADENSTVÍ',
                    navAboutUs: 'O NÁS',
                    navInsights: 'POZNATKY',
                    navContact: 'KONTAKT',
                    categoryBadge: 'Novinky',
                    articleTitle: 'Diskuse se studenty University of Connecticut School of Business',
                    articleDate: '30. března 2022',
                    backLink: 'Zpět na poznatky',
                    intro: 'V březnu byla Lucie Melicharová hostem semináře pro studenty Executive MBA na americké University of Connecticut School of Business. Tématem semináře byl koncept Well-being na pracovišti a současné výzvy v době pandemie i války.',
                    section1Title: 'Koncept Well-being na pracovišti',
                    section1Para1:
                        'Hlavními body diskuze byly koncept well-being z pohledu HR, jeho vývoj ve světě i v evropském prostředí, dopady pandemie COVID 19 a současné války na Ukrajině.',
                    donationNote: '🇺🇦 Lucie Melicharová se vzdala honoráře ve prospěch příspěvku nadaci Člověk v tísni na projekt SOS Ukrajina.',
                    footerServices: 'Služby',
                    headhuntingTitle: 'Headhunting',
                    hrTitle: 'HR Poradenství',
                    footerCompany: 'Společnost',
                    footerAbout: 'O nás',
                    footerTeam: 'Tým',
                    footerInsights: 'Poznatky',
                    privacyText: 'Respektujeme vysoké standardy ochrany soukromí. Přečtěte si více o našich',
                    privacyLink: 'Zásadách ochrany osobních údajů a prohlášení o cookies',
                    copyright: 'Copyright © 2002–2026 learn2grow'
                }
            };

            // Apply translations
            function applyTranslations(lang) {
                document.querySelectorAll('[data-i18n]').forEach((element) => {
                    const key = element.getAttribute('data-i18n');
                    if (translations[lang] && translations[lang][key]) {
                        element.textContent = translations[lang][key];
                    }
                });
            }

            // Set initial language
            langBtns.forEach((btn) => {
                if (btn.dataset.lang === currentLang) {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            });

            applyTranslations(currentLang);

            // Language button click handlers
            langBtns.forEach((btn) => {
                btn.addEventListener('click', () => {
                    const lang = btn.dataset.lang;
                    currentLang = lang;
                    localStorage.setItem('language', lang);

                    langBtns.forEach((b) => b.classList.remove('active'));
                    btn.classList.add('active');

                    applyTranslations(lang);
                });
            });

            // Navbar scroll effect
            const navbar = document.getElementById('navbar');
            window.addEventListener('scroll', () => {
                if (window.scrollY > 50) {
                    navbar.classList.add('scrolled');
                } else {
                    navbar.classList.remove('scrolled');
                }
            });

            // Cookie consent
            const cookieBanner = document.getElementById('cookieBanner');
            const acceptBtn = document.getElementById('cookieAccept');
            const declineBtn = document.getElementById('cookieDecline');

            if (!localStorage.getItem('cookieConsent')) {
                setTimeout(() => {
                    cookieBanner.classList.add('show');
                }, 1000);
            }

            acceptBtn.addEventListener('click', () => {
                localStorage.setItem('cookieConsent', 'accepted');
                cookieBanner.classList.remove('show');
            });

            declineBtn.addEventListener('click', () => {
                localStorage.setItem('cookieConsent', 'declined');
                cookieBanner.classList.remove('show');
            });
        </script>
    </body>
</html>
