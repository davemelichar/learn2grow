---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/globals.css';
---

<Layout title="Talent, Learning, and the Future of AI - learn2grow">

<Nav />

<!-- Article Header -->
<header class="article-header">
    <span class="article-category-badge" data-i18n="articleCategory">News</span>
    <h1 class="article-title" data-i18n="articleTitle">An Inspiring Meeting on Talent, Learning, and the Future of AI</h1>
    <p class="article-meta" data-i18n="articleDate">May 18, 2023</p>
</header>

<!-- Article Content -->
<article class="article-content">
    <a href="/insights" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"></path>
        </svg>
        <span data-i18n="backToInsights">Back to Insights</span>
    </a>

    <div class="article-image-block">
        <img loading="lazy" src="/images/article5.jpg" alt="Panel discussion with Texas A&M students" />
    </div>

    <div class="article-intro">
        <p data-i18n="articleIntro">Last Thursday, we had the honour of being part of an inspiring morning dedicated to topics currently shaping the world of modern business: new talent, learning processes, and the role of artificial intelligence.</p>
    </div>

    <section class="article-section">
        <p data-i18n="body1">Lucie Melicharová took on the role of a speaker in a panel discussion with students of the Texas A&M master's programme, where alongside other experts she shared her perspective on the never-ending learning process and AI and technology-driven changes in the labour market.</p>
        <p data-i18n="body2">For learn2grow, conversations with the next generation of business leaders are always particularly valuable. Students bring fresh perspectives and probing questions — and their view of what the workplace of the future should look like often challenges assumptions that seasoned professionals take for granted.</p>
        <p data-i18n="body3">The intersection of talent strategy and emerging technology is one of the defining challenges of our time. How organisations attract and develop people in an AI-enabled world is a question every leader needs to be actively thinking about — not as a future concern, but as a present one.</p>
    </section>

    <p class="article-source" data-i18n="source">Source: LinkedIn</p>
</article>

<Footer />

</Layout>

<style is:global>
    .article-title {
        font-family: 'DM Sans', sans-serif;
        font-size: 3.5rem;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 1rem;
        line-height: 1.2;
    }
    .article-subtitle {
        font-size: 1.5rem;
        color: var(--text-light);
        font-style: italic;
        margin-bottom: 1.5rem;
    }
    .article-meta { font-size: 0.95rem; color: var(--text-light); }
    @media (max-width: 900px) {
        .article-title { font-size: 2.5rem; }
        .article-subtitle { font-size: 1.2rem; }
    }
</style>

<script>
    import { sharedTranslations } from '../i18n/translations';

const langBtns = document.querySelectorAll('.lang-btn') as NodeListOf<HTMLButtonElement>;
let currentLang: string = localStorage.getItem('language') || 'en';

const translations: Record<string, Record<string, string>> = {
    en: {
        ...sharedTranslations.en,
        articleCategory: 'News',
        articleTitle: 'An Inspiring Meeting on Talent, Learning, and the Future of AI',
        articleDate: 'May 18, 2023',
        articleIntro: 'Last Thursday, we had the honour of being part of an inspiring morning dedicated to topics currently shaping the world of modern business: new talent, learning processes, and the role of artificial intelligence.',
        body1: 'Lucie Melicharová took on the role of a speaker in a panel discussion with students of the Texas A&M master\'s programme, where alongside other experts she shared her perspective on the never-ending learning process and AI and technology-driven changes in the labour market.',
        body2: 'For learn2grow, conversations with the next generation of business leaders are always particularly valuable. Students bring fresh perspectives and probing questions — and their view of what the workplace of the future should look like often challenges assumptions that seasoned professionals take for granted.',
        body3: 'The intersection of talent strategy and emerging technology is one of the defining challenges of our time. How organisations attract and develop people in an AI-enabled world is a question every leader needs to be actively thinking about — not as a future concern, but as a present one.',
        source: 'Source: LinkedIn',
    },
    cs: {
        ...sharedTranslations.cs,
        articleCategory: 'Aktuality',
        articleTitle: 'Inspirativní setkání o talentech, vzdělávání a budoucnosti AI',
        articleDate: '18. května 2023',
        articleIntro: 'Minulý čtvrtek jsme měli tu čest být součástí inspirativního dopoledne, které se věnovalo tématům, jež aktuálně hýbou světem moderního byznysu: novým talentům, procesům učení a roli umělé inteligence.',
        body1: 'Lucie Melicharová se zhostila role speakera v rámci panelové diskuse se studenty magisterského programu Texas A&M, kde spolu s dalšími odborníky sdílela pohled na nikdy nekončící proces učení a změny na trhu práce poháněné umělou inteligencí a technologiemi.',
        body2: 'Pro learn2grow jsou rozhovory s novou generací obchodních lídrů vždy zvlášť cenné. Studenti přinášejí svěží perspektivy a pronikavé otázky — a jejich pohled na to, jak by mělo vypadat pracoviště budoucnosti, často zpochybňuje předpoklady, které zkušení profesionálové považují za samozřejmost.',
        body3: 'Průsečík strategie talentů a nových technologií je jednou z klíčových výzev naší doby. Jak organizace přitahují a rozvíjejí lidi v době umožněné AI, je otázka, nad kterou musí každý lídr aktivně přemýšlet — ne jako o budoucím problému, ale jako o dnešním.',
        source: 'Zdroj: LinkedIn',
    }
};

function setLanguage(lang: string): void {
    currentLang = lang;
    localStorage.setItem('language', lang);
    document.documentElement.lang = lang === 'cs' ? 'cs' : 'en';
    langBtns.forEach(btn => btn.classList.toggle('active', btn.dataset.lang === lang));
    const t = translations[lang];
    document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n')!;
        if (t[key]) el.innerHTML = t[key];
    });
}
langBtns.forEach(btn => btn.addEventListener('click', () => setLanguage(btn.dataset.lang!)));
setLanguage(currentLang);

window.addEventListener('scroll', () => {
    document.querySelector('nav')!.classList.toggle('scrolled', window.scrollY > 50);
});

</script>
