---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/globals.css';
---

<Layout title="Top 5 HR Trends for 2024 - learn2grow">

<Nav />

<!-- Article Header -->
<header class="article-header">
    <span class="article-category-badge" data-i18n="articleCategory">News</span>
    <h1 class="article-title" data-i18n="articleTitle">An Inspiring Morning with Lucie Melicharová: Top 5 HR Trends for 2024</h1>
    <p class="article-meta" data-i18n="articleDate">February 19, 2024</p>
</header>

<!-- Article Content -->
<article class="article-content">
    <a href="/insights" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"></path>
        </svg>
        <span data-i18n="backToInsights">Back to Insights</span>
    </a>

    <div class="article-image-block">
        <img loading="lazy" src="/images/article4.jpg" alt="Business Friends Networking Breakfast" />
    </div>

    <div class="article-intro">
        <p data-i18n="articleIntro">Another networking breakfast organised by the Business Friends platform took place in the pleasant setting of the Hodkovičky Golf Club, featuring Lucie Melicharová as the guest speaker.</p>
    </div>

    <section class="article-section">
        <p data-i18n="body1">Lucie presented the Top 5 HR trends for 2024 that are currently shaping the labour market. She focused on the evolving role of HR, the growing emphasis on people development, company culture, and the ability to respond to a rapidly changing work environment.</p>
        <p data-i18n="body2">The discussion centred particularly on workforce flexibility — how organisations adapt to hybrid work models, shifting employee expectations, and the generational dynamics of today's teams. The impact of AI on human resources was, naturally, a central thread running through the entire conversation.</p>
        <p data-i18n="body3">Events like these create valuable space for leaders to step away from day-to-day pressures and engage with the bigger picture: where is HR heading, and what does that mean for how we attract, develop, and retain the people who drive our organisations forward?</p>
    </section>

    <p class="article-source" data-i18n="source">Source: LinkedIn</p>
</article>

<Footer />

</Layout>

<style is:global>
    .article-title {
        font-family: 'DM Sans', sans-serif;
        font-size: 3.5rem;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 1rem;
        line-height: 1.2;
    }
    .article-subtitle {
        font-size: 1.5rem;
        color: var(--text-light);
        font-style: italic;
        margin-bottom: 1.5rem;
    }
    .article-meta { font-size: 0.95rem; color: var(--text-light); }
    @media (max-width: 900px) {
        .article-title { font-size: 2.5rem; }
        .article-subtitle { font-size: 1.2rem; }
    }
</style>

<script>
    import { sharedTranslations } from '../i18n/translations';

const langBtns = document.querySelectorAll('.lang-btn') as NodeListOf<HTMLButtonElement>;
let currentLang: string = localStorage.getItem('language') || 'en';

const translations: Record<string, Record<string, string>> = {
    en: {
        ...sharedTranslations.en,
        articleCategory: 'News',
        articleTitle: 'An Inspiring Morning with Lucie Melicharová: Top 5 HR Trends for 2024',
        articleDate: 'February 19, 2024',
        articleIntro: 'Another networking breakfast organised by the Business Friends platform took place in the pleasant setting of the Hodkovičky Golf Club, featuring Lucie Melicharová as the guest speaker.',
        body1: 'Lucie presented the Top 5 HR trends for 2024 that are currently shaping the labour market. She focused on the evolving role of HR, the growing emphasis on people development, company culture, and the ability to respond to a rapidly changing work environment.',
        body2: 'The discussion centred particularly on workforce flexibility — how organisations adapt to hybrid work models, shifting employee expectations, and the generational dynamics of today\'s teams. The impact of AI on human resources was, naturally, a central thread running through the entire conversation.',
        body3: 'Events like these create valuable space for leaders to step away from day-to-day pressures and engage with the bigger picture: where is HR heading, and what does that mean for how we attract, develop, and retain the people who drive our organisations forward?',
        source: 'Source: LinkedIn',
    },
    cs: {
        ...sharedTranslations.cs,
        articleCategory: 'Aktuality',
        articleTitle: 'Inspirativní ráno s Lucií Melicharovou: Top 5 (nejen) HR trendů pro rok 2024',
        articleDate: '19. února 2024',
        articleIntro: 'Další síťovací snídaně platformy Business Friends proběhla v příjemném prostředí Golf Clubu Hodkovičky. Jako host vystoupila Lucie Melicharová.',
        body1: 'Lucie představila Top 5 HR trendů pro rok 2024, které aktuálně definují trh práce. Zaměřila se na proměnu role HR, větší důraz na rozvoj lidí, firemní kulturu a schopnost reagovat na rychle se měnící pracovní prostředí.',
        body2: 'Diskuze se věnovala zejména flexibilitě pracovní síly — jak se organizace adaptují na hybridní pracovní modely, měnící se očekávání zaměstnanců a generační dynamiku dnešních týmů. Vliv AI na lidské zdroje byl přirozeně ústředním tématem celé diskuse.',
        body3: 'Setkání jako tato vytvářejí cenný prostor pro lídry, aby se na chvíli odtrhli od každodenního tlaku a zabývali se větším obrazem: Kam HR směřuje a co to znamená pro způsob, jakým přitahujeme, rozvíjíme a udržujeme lidi, kteří pohánějí naše organizace vpřed?',
        source: 'Zdroj: LinkedIn',
    }
};

function setLanguage(lang: string): void {
    currentLang = lang;
    localStorage.setItem('language', lang);
    document.documentElement.lang = lang === 'cs' ? 'cs' : 'en';
    langBtns.forEach(btn => btn.classList.toggle('active', btn.dataset.lang === lang));
    const t = translations[lang];
    document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n')!;
        if (t[key]) el.innerHTML = t[key];
    });
}
langBtns.forEach(btn => btn.addEventListener('click', () => setLanguage(btn.dataset.lang!)));
setLanguage(currentLang);

window.addEventListener('scroll', () => {
    document.querySelector('nav')!.classList.toggle('scrolled', window.scrollY > 50);
});

</script>
