---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/globals.css';
---

<Layout title="Preparing Leaders for the Era of Physical AI - learn2grow">

<Nav />

<!-- Article Header -->
<header class="article-header">
    <span class="article-category-badge" data-i18n="articleCategory">News</span>
    <h1 class="article-title" data-i18n="articleTitle">Lucie Melicharová at Exponential Circles: Preparing Leaders for the Era of Physical AI</h1>
    <p class="article-meta" data-i18n="articleDate">December 12, 2025</p>
</header>

<!-- Article Content -->
<article class="article-content">
    <a href="/insights" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"></path>
        </svg>
        <span data-i18n="backToInsights">Back to Insights</span>
    </a>

    <div class="article-image-block">
        <img loading="lazy" src="/images/article2.jpg" alt="Lucie Melicharová at Exponential Circles" />
    </div>

    <div class="article-intro">
        <p data-i18n="articleIntro">The past year belonged to reasoning and agentic AI. However, the current topic making waves in leadership and business circles is Physical AI — the emergence of artificial intelligence into the physical world through robotics, autonomous logistics, and smart operations.</p>
    </div>

    <section class="article-section">
        <p data-i18n="body1">Lucie Melicharová participated in the Exponential Circles meeting as a panelist, where alongside leading experts she discussed the far-reaching implications of this shift for business strategy and human resources. The conversation brought together investors, technology developers, and organisational leaders all navigating the same fundamental question: how do you lead in a world where your workforce is no longer exclusively human?</p>
        <p data-i18n="body2">For learn2grow, Physical AI is not just a technological trend — it represents a fundamental change in how we define leadership and working teams. Identifying top executives now goes beyond searching for people alone. Future leaders must be able to manage hybrid ecosystems where humans, AI agents, and humanoid robots function side by side.</p>
        <p data-i18n="body3">The skills that will differentiate exceptional leaders in this era are not primarily technical. They are the same human capacities we have always valued — clear thinking, the ability to build trust across diverse teams, and the courage to make decisions under uncertainty — applied now in a context that is genuinely unprecedented.</p>
    </section>
</article>

<Footer />

</Layout>

<style is:global>
    .article-title {
        font-family: 'DM Sans', sans-serif;
        font-size: 3.5rem;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 1rem;
        line-height: 1.2;
    }
    .article-subtitle {
        font-size: 1.5rem;
        color: var(--text-light);
        font-style: italic;
        margin-bottom: 1.5rem;
    }
    .article-meta { font-size: 0.95rem; color: var(--text-light); }
    @media (max-width: 900px) {
        .article-title { font-size: 2.5rem; }
        .article-subtitle { font-size: 1.2rem; }
    }
</style>

<script>
    import { sharedTranslations } from '../i18n/translations';

const langBtns = document.querySelectorAll('.lang-btn') as NodeListOf<HTMLButtonElement>;
let currentLang: string = localStorage.getItem('language') || 'en';

const translations: Record<string, Record<string, string>> = {
    en: {
        ...sharedTranslations.en,
        articleCategory: 'News',
        articleTitle: 'Lucie Melicharová at Exponential Circles: Preparing Leaders for the Era of Physical AI',
        articleDate: 'December 12, 2025',
        articleIntro: 'The past year belonged to reasoning and agentic AI. However, the current topic making waves in leadership and business circles is Physical AI — the emergence of artificial intelligence into the physical world through robotics, autonomous logistics, and smart operations.',
        body1: 'Lucie Melicharová participated in the Exponential Circles meeting as a panelist, where alongside leading experts she discussed the far-reaching implications of this shift for business strategy and human resources. The conversation brought together investors, technology developers, and organisational leaders all navigating the same fundamental question: how do you lead in a world where your workforce is no longer exclusively human?',
        body2: 'For learn2grow, Physical AI is not just a technological trend — it represents a fundamental change in how we define leadership and working teams. Identifying top executives now goes beyond searching for people alone. Future leaders must be able to manage hybrid ecosystems where humans, AI agents, and humanoid robots function side by side.',
        body3: 'The skills that will differentiate exceptional leaders in this era are not primarily technical. They are the same human capacities we have always valued — clear thinking, the ability to build trust across diverse teams, and the courage to make decisions under uncertainty — applied now in a context that is genuinely unprecedented.',
    },
    cs: {
        ...sharedTranslations.cs,
        articleCategory: 'Aktuality',
        articleTitle: 'Lucie Melicharová na Exponential Circles: Připravujeme lídry na éru Physical AI',
        articleDate: '12. prosince 2025',
        articleIntro: 'Poslední rok patřil zejména agentní AI. Aktuálním tématem, které hýbe světem leadershipu a byznysu, je ale Physical AI – vstup umělé inteligence do fyzického světa prostřednictvím robotiky, autonomní logistiky a chytrých provozů.',
        body1: 'Lucie Melicharová se zúčastnila setkání Exponential Circles jako panelistka, kde spolu s předními odborníky diskutovala o dalekosáhlých dopadech tohoto posunu na byznys strategii a lidské zdroje. Setkání sdružilo investory, vývojáře technologií a organizační lídry, kteří všichni čelí stejné zásadní otázce: jak vést v době, kdy vaše pracovní síla není výhradně lidská?',
        body2: 'Pro learn2grow není Physical AI jen technologický trend — představuje zásadní změnu v tom, jak definujeme leadership a pracovní týmy. Vyhledávání top manažerů dnes neznamená jen hledat lidi. Lídři budoucnosti musí umět řídit hybridní ekosystémy, kde vedle sebe fungují lidé, AI agenti a humanoidní roboti.',
        body3: 'Dovednosti, které budou odlišovat výjimečné lídry v této éře, nejsou primárně technické. Jsou to stejné lidské schopnosti, které jsme vždy oceňovali — jasné myšlení, schopnost budovat důvěru napříč různorodými týmy a odvaha rozhodovat se v nejistotě — nyní aplikované v kontextu, který je skutečně bezprecedentní.',
    }
};

function setLanguage(lang: string): void {
    currentLang = lang;
    localStorage.setItem('language', lang);
    document.documentElement.lang = lang === 'cs' ? 'cs' : 'en';
    langBtns.forEach(btn => btn.classList.toggle('active', btn.dataset.lang === lang));
    const t = translations[lang];
    document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n')!;
        if (t[key]) el.innerHTML = t[key];
    });
}
langBtns.forEach(btn => btn.addEventListener('click', () => setLanguage(btn.dataset.lang!)));
setLanguage(currentLang);

window.addEventListener('scroll', () => {
    document.querySelector('nav')!.classList.toggle('scrolled', window.scrollY > 50);
});

</script>
