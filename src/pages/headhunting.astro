                    <br>
                    <p>(+420) 773 923 402</p>
                    <p>(+420) 241 404 170</p>
                    <p>info@learn2grow.cz</p>
                </div>
            </div>

            <div>
                <h4 style="margin-bottom: 1.5rem;">Services</h4>
                <ul class="footer-links">
                    <li><a href="/headhunting">Headhunting</a></li>
                    <li><a href="/hr-consulting">HR Consulting</a></li>
                    <li><a href="/people-development">People Development</a></li>
                </ul>
            </div>

            <div>
                <h4 style="margin-bottom: 1.5rem;">Company</h4>
                <ul class="footer-links">
                    <li><a href="/about">About Us</a></li>
                    <li><a href="/">Team</a></li>
