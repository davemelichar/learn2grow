<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Headhunting | learn2grow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #0F172A;
            --secondary: #1E293B;
            --accent: #F97316;
            --orange: #F97316;
            --light: #ffffff;
            --text: #334155;
            --text-light: #64748B;
            --surface: #F8FAFC;
            --border: #E2E8F0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            color: var(--text);
            line-height: 1.7;
            overflow-x: hidden;
            background: var(--surface);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        nav {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            z-index: 1000;
            padding: 1rem 0;
            border-bottom: 1px solid var(--border);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        nav.scrolled {
            padding: 0.75rem 0;
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 4px 24px rgba(0,0,0,0.06);
        }

        .nav-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            display: block;
            height: 48px;
            transition: height 0.3s ease;
        }

        nav.scrolled .logo {
            height: 36px;
        }

        .logo img {
            height: 100%;
            width: auto;
        }

        .nav-links {
            display: flex;
            gap: 2.25rem;
            list-style: none;
            margin-left: 4rem;
        }

        .nav-links a {
            color: var(--text);
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 500;
            letter-spacing: 0.05em;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            padding-bottom: 4px;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--orange), #EA580C);
            border-radius: 2px;
            transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        .nav-links a:hover {
            color: var(--primary);
        }

        .nav-links a.active::after {
            width: 100%;
        }

        .nav-links a.active {
            color: var(--primary);
            font-weight: 600;
        }

        .content {
            max-width: 1400px;
            margin: 120px auto 80px;
            padding: 0 2rem;
        }

        h1 {
            font-family: 'DM Sans', sans-serif;
            font-size: 3.5rem;
            color: var(--primary);
            margin-bottom: 2rem;
        }

        p {
            font-size: 1.1rem;
            color: var(--text-light);
            margin-bottom: 2rem;
            line-height: 1.9;
        }

        h2 {
            font-family: 'DM Sans', sans-serif;
            font-size: 2.5rem;
            color: var(--primary);
            margin-top: 0;
            margin-bottom: 1.5rem;
        }

        .image-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            align-items: center;
            margin-bottom: 4rem;
        }

        .image-section img {
            width: 100%;
            border-radius: 15px;
        }

        @media (max-width: 768px) {
            .image-section {
                grid-template-columns: 1fr;
            }
        }

        footer {
            background: var(--primary);
            color: white;
            padding: 4rem 2rem 2rem;
            margin-top: 8rem;
        }

        .footer-container {
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 2fr 1fr 1fr;
            gap: 4rem;
            margin-bottom: 3rem;
        }

        .footer-logo {
            font-family: 'DM Sans', sans-serif;
            font-size: 2rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
        }

        .footer-contact p {
            opacity: 0.8;
            margin-bottom: 0.5rem;
        }

        .footer-links {
            list-style: none;
        }

        .footer-links li {
            margin-bottom: 0.8rem;
        }

        .footer-links a {
            color: white;
            text-decoration: none;
            opacity: 0.8;
            transition: opacity 0.3s ease;
        }

        .footer-links a:hover {
            opacity: 1;
        }

        .footer-bottom {
            text-align: center;
            padding-top: 2rem;
            border-top: 1px solid rgba(255,255,255,0.1);
            opacity: 0.6;
        }

        @media (max-width: 768px) {
            .nav-links {
                display: none;
            }

            h1 {
                font-size: 2rem;
            }

            .footer-container {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
        }
    </style>
</head>
<body>
    <nav id="navbar">
