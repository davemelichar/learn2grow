---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/globals.css';

const articles = await getCollection('articles');
articles.sort((a, b) => a.data.order - b.data.order);

const articlesData = articles.map(a => ({
    id: a.id,
    image: a.data.image,
    category: a.data.category,
    date_en: a.data.date_en,
    date_cs: a.data.date_cs,
    title_en: a.data.title_en,
    title_cs: a.data.title_cs,
    excerpt_en: a.data.excerpt_en,
    excerpt_cs: a.data.excerpt_cs,
}));
---

<Layout title="Insights - learn2grow">
    <Nav />

    <section class="hero">
        <h1 data-i18n="insightsTitle">Insights</h1>
        <p data-i18n="insightsDescription">
            Explore our latest articles, research, and thought leadership on executive search, HR consulting, and organizational development.
        </p>
    </section>

    <main class="container">
        <div class="articles-grid">
            {articles.map(a => (
                <article class="article-card">
                    <div class="article-image" style={`background-image: url('${a.data.image}');`}>
                        <div class="article-category">
                            <span class="category-badge" data-i18n={`${a.id}_category`}>{a.data.category}</span>
                        </div>
                    </div>
                    <div class="article-body">
                        <p class="article-date" data-i18n={`${a.id}_date`}>{a.data.date_en}</p>
                        <h2 class="article-title" data-i18n={`${a.id}_title`}>{a.data.title_en}</h2>
                        <p class="article-excerpt" data-i18n={`${a.id}_excerpt`}>{a.data.excerpt_en}</p>
                        <a href={`/${a.id}`} class="read-more-link" data-i18n="readMore">
                            Read more
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                ><path d="M5 12h14M12 5l7 7-7 7"></path></svg
                            >
                        </a>
                    </div>
                </article>
            ))}
        </div>
    </main>

    <Footer />
</Layout>

<style is:global>
    .hero {
        margin-top: 70px;
        background: linear-gradient(135deg, #fff, #ffe8d1);
        padding: 6rem 2rem 4rem;
        text-align: center;
    }
    .hero h1 {
        font-family: 'DM Sans', sans-serif;
        font-size: 3.5rem;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 1rem;
    }
    .hero p {
        font-size: 1.2rem;
        color: var(--text-light);
        max-width: 700px;
        margin: 0 auto;
    }
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 2rem;
    }
    .articles-grid {
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 3rem;
        margin-bottom: 4rem;
    }
    .article-image {
        height: 240px;
        background-size: cover;
        background-position: center;
        position: relative;
    }
    .article-category {
        position: absolute;
        bottom: 1.5rem;
        left: 1.5rem;
    }
    .article-title {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 1rem;
        line-height: 1.4;
    }
    @media (max-width: 768px) {
        .hero h1 { font-size: 2.5rem; }
        .articles-grid { grid-template-columns: 1fr; }
    }
</style>

<script define:vars={{ articlesData }}>
    window.__articlesData = articlesData;
</script>

<script>
    import { sharedTranslations } from '../i18n/translations';

    const langBtns = document.querySelectorAll('.lang-btn') as NodeListOf<HTMLButtonElement>;
    let currentLang: string = localStorage.getItem('language') || 'en';

    type ArticleData = {
        id: string; category: string;
        date_en: string; date_cs: string;
        title_en: string; title_cs: string;
        excerpt_en: string; excerpt_cs: string;
    };
    const articlesData: ArticleData[] = (window as any).__articlesData || [];

    const articleTranslations = { en: {} as Record<string, string>, cs: {} as Record<string, string> };
    for (const a of articlesData) {
        articleTranslations.en[`${a.id}_category`] = a.category === 'Articles' ? 'Articles' : 'News';
        articleTranslations.cs[`${a.id}_category`] = a.category === 'Articles' ? 'Články' : 'Aktuality';
        articleTranslations.en[`${a.id}_date`]    = a.date_en;
        articleTranslations.cs[`${a.id}_date`]    = a.date_cs;
        articleTranslations.en[`${a.id}_title`]   = a.title_en;
        articleTranslations.cs[`${a.id}_title`]   = a.title_cs;
        articleTranslations.en[`${a.id}_excerpt`] = a.excerpt_en;
        articleTranslations.cs[`${a.id}_excerpt`] = a.excerpt_cs;
    }

    const translations: Record<string, Record<string, string>> = {
        en: {
            ...sharedTranslations.en,
            ...articleTranslations.en,
            insightsTitle: 'Insights',
            insightsDescription:
                'Explore our latest articles, research, and thought leadership on executive search, HR consulting, and organizational development.',
        },
        cs: {
            ...sharedTranslations.cs,
            ...articleTranslations.cs,
            insightsTitle: 'Novinky',
            insightsDescription:
                'Prozkoumejte naše nejnovější články, výzkum a myšlenkové vedení v oblasti executive search, HR poradenství a organizačního rozvoje.',
        },
    };

    function setLanguage(lang: string): void {
        currentLang = lang;
        localStorage.setItem('language', lang);
        document.documentElement.lang = lang === 'cs' ? 'cs' : 'en';
        langBtns.forEach((btn) => btn.classList.toggle('active', btn.dataset.lang === lang));
        const t = translations[lang];
        document.querySelectorAll('[data-i18n]').forEach((el) => {
            const key = el.getAttribute('data-i18n')!;
            if (t[key]) el.innerHTML = t[key];
        });
    }
    langBtns.forEach((btn) => btn.addEventListener('click', () => setLanguage(btn.dataset.lang!)));
    setLanguage(currentLang);

    window.addEventListener('scroll', () => {
        document.querySelector('nav')!.classList.toggle('scrolled', window.scrollY > 50);
    });
</script>
