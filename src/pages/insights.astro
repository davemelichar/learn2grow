                    <li style="margin-bottom: 0.75rem;"><a href="/#headhunting" class="footer-link" data-i18n="headhuntingTitle">Headhunting</a></li>
                    <li style="margin-bottom: 0.75rem;"><a href="/#hr-consulting" class="footer-link" data-i18n="hrTitle">HR Consulting</a></li>
                </ul>
